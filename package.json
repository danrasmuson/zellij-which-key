{
  "name": "zellij-which-key",
  "version": "0.1.0",
  "description": "which-key style leader-key launcher for zellij, rendered with Ink",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "zellij-which-key": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsc",
    "start": "node dist/index.js",
    "prepublishOnly": "pnpm build"
  },
  "keywords": ["zellij", "which-key", "leader", "tui", "ink"],
  "author": "Dan Rasmuson",
  "license": "MIT",
  "packageManager": "pnpm@10.20.0",
  "dependencies": {
    "ink": "^6.8.0",
    "react": "^19.2.4",
    "yaml": "^2.5.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
